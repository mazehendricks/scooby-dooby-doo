# Robinhood API Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# Robinhood Credentials
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password_here
ROBINHOOD_MFA_CODE=  # Leave empty if using TOTP, or provide SMS code

# Optional: TOTP Secret (if using authenticator app)
# Get this from Robinhood security settings
ROBINHOOD_TOTP_SECRET=

# API Configuration
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_in_production
FLASK_PORT=5000
FLASK_DEBUG=False

# Safety Limits (Circuit Breaker Configuration)
MAX_DAILY_TRADES=50
MAX_POSITION_SIZE_PERCENT=15.0  # Max % of portfolio per position
MAX_DAILY_LOSS_PERCENT=5.0      # Stop trading if daily loss exceeds this
MIN_ACCOUNT_BALANCE=1000.0      # Minimum account balance to maintain
ENABLE_PAPER_TRADING=True       # Set to False for real trading (USE WITH CAUTION!)

# Rate Limiting
API_RATE_LIMIT=60  # Max API calls per minute

# Logging
LOG_LEVEL=INFO
LOG_FILE=trading_bot.log
